#!/bin/bash

# --- Identity Setup ---
export MY_UID=$(id -u)
export MY_GID=$(id -g)
export MY_USER=$USER
export MY_GROUP=$(id -gn)

SERVICE_NAME="node_base"

# --- Path Setup ---
export REPO=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
export IMAGE_NAME=$SERVICE_NAME
export CONTAINER_NAME=$SERVICE_NAME

# Load node version (ensure this file exists in the repo)
if [ -f "$REPO/node_v" ]; then
    source "$REPO/node_v"
fi

# --- Podman Command Setup ---
COMPOSE_CMD="podman compose"
YAML_FILE="$REPO/docker-compose.yml"

######################################################

function nuke() {
    # Podman has a very convenient 'system prune' that handles most of this
    podman system prune -a -f --volumes
}

function up() {
    $COMPOSE_CMD -f "$YAML_FILE" up -d --no-build ${SERVICE_NAME}
}

function down() {
    $COMPOSE_CMD -f "$YAML_FILE" down
}

function restart() {
    down
    up
}

function shell() {
    # Podman exec works identically
    $COMPOSE_CMD -f "$YAML_FILE" exec ${SERVICE_NAME} bash
}

function purge() {
    $COMPOSE_CMD -f "$YAML_FILE" down --rmi all --volumes --remove-orphans
}

function build() {
    purge
    $COMPOSE_CMD -f "$YAML_FILE" build --no-cache ${SERVICE_NAME}
    nuke
}

function logs() {
    $COMPOSE_CMD -f "$YAML_FILE" logs -f ${SERVICE_NAME}
}

function env_var() {
    # Standard podman inspect works fine here
    podman inspect ${CONTAINER_NAME} 2>/dev/null | jq '.[0].Config.Env'
}

function passthrough() {
    $COMPOSE_CMD -f "$YAML_FILE" exec ${SERVICE_NAME} "$@"
}

######################################################

case "$1" in
    nuke)       nuke ;;
    up)         up ;;
    down)       down ;;
    restart)    restart ;;
    shell)      shell ;;
    purge)      purge ;;
    build)      build ;;
    logs)       logs ;;
    env_var)    env_var ;;
    *)
    passthrough "$@" ;;
esac
